import { ethers } from "hardhat";
import { expect } from "chai";

describe("Proof config admin", () => {
  it("sets verifier and requirement", async () => {
    const [admin, user] = await ethers.getSigners();

    const CP = await ethers.getContractFactory("ChallengePay");
    const cp = await CP.deploy(/* constructor args */);
    await cp.waitForDeployment();

    const ZK = await ethers.getContractFactory("ZkProofVerifier");
    const zk = await ZK.deploy();
    await zk.waitForDeployment();

    // assume challenge #1 exists in your tests, or create one here
    await expect(cp.connect(user).setProofConfig(1, true, await zk.getAddress()))
      .to.be.reverted; // NotAdmin / onlyOwner

    const tx = await cp.connect(admin).setProofConfig(1, true, await zk.getAddress());
    await tx.wait();
    // optionally read back and assert via a public getter if you have one
  });
});