{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["hardhat", "hardhat-deploy", "node", "mocha", "chai"],
    "sourceMap": true,
    "composite": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "hardhat.config.ts",
    "scripts/**/*",
    "test/**/*",
    "typechain-types/**/*"
  ],
  "exclude": ["webapp", "node_modules", "dist"],
  "ts-node": {
    "files": true,
    "transpileOnly": true
  }
}