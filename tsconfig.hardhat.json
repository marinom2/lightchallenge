{
    "compilerOptions": {
      "target": "ES2020",
      "lib": ["ES2020"],
      "module": "commonjs",
      "moduleResolution": "node",
      "outDir": "./dist",
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "skipLibCheck": true,
      "strict": true,
      "declaration": false,
      "forceConsistentCasingInFileNames": true,
      "types": ["node", "mocha", "chai", "hardhat"],
      "sourceMap": true
    },
    "include": [
      "hardhat.config.ts",
      "scripts/**/*",
      "test/**/*",
      "typechain-types/**/*",
      "contracts/**/*.ts",
      "contracts/test/MetadataRegistry.spec.ts"
    ],
    "exclude": ["webapp", "node_modules", "dist"],
    "ts-node": {
      "files": true,
      "transpileOnly": true
    }
  }