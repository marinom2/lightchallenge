{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["hardhat", "hardhat-deploy", "node", "mocha", "chai"],
    "noEmit": true
  },
  "include": [
    "hardhat.config.ts",
    "deploy/**/*.ts",
    "scripts/**/*.ts",
    "tasks/**/*.ts",
    "test/**/*.ts",
    "typechain-types/**/*.ts",
    "offchain/**/*.ts"
, "scripts/manual/create-challenge-standalone.mjs"  ]
}