{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NormalizedActivities",
  "type": "object",
  "required": ["athlete", "activities"],
  "properties": {
    "athlete": {
      "type": "object",
      "required": ["address"],
      "properties": {
        "address": { "type": "string" },
        "source": { "type": "string", "enum": ["strava", "garmin", "apple_health", "fitbit", "manual_ocr"] }
      }
    },
    "activities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "start", "end"],
        "properties": {
          "type": { "type": "string", "enum": ["run", "walk", "cycle", "swim", "steps"] },
          "start": { "type": "string", "format": "date-time" },
          "end": { "type": "string", "format": "date-time" },
          "distance_km": { "type": "number" },
          "duration_min": { "type": "number" },
          "avg_hr_bpm": { "type": "number" },
          "max_hr_bpm": { "type": "number" },
          "elev_gain_m": { "type": "number" },
          "steps_count": { "type": "number" },
          "gps_path": { "type": "array", "items": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 } }
        }
      }
    }
  }
}
