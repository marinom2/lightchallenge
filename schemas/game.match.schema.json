{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "game.match.schema.json",
    "title": "Game match normalized payload",
    "type": "object",
    "required": ["platform", "matchId", "participants", "winners", "metadata"],
    "properties": {
      "platform": { "type": "string", "enum": ["dota2", "lol"] },
      "matchId": { "type": "string" },
      "participants": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["wallet", "platformId"],
          "properties": {
            "wallet": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
            "platformId": { "type": "string" },
            "handle": { "type": "string" },
            "team": { "type": "string" }
          }
        }
      },
      "winners": { "type": "array", "items": { "type": "string" } },
      "losers": { "type": "array", "items": { "type": "string" } },
      "metadata": {
        "type": "object",
        "properties": {
          "startTime": { "type": "integer" },
          "durationSec": { "type": "integer" },
          "raw": {}
        },
        "additionalProperties": true
      },
      "binding": {
        "type": "object",
        "required": ["challengeId", "subjectHash"],
        "properties": {
          "challengeId": { "type": "string" },
          "subjectHash": { "type": "string" }
        }
      }
    },
    "additionalProperties": false
  }