{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "PersonalChallenge",
    "type": "object",
    "properties": {
      "kind": { "const": "Personal" },
      "title": { "type": "string" },
      "description": { "type": "string" },
      "image": { "type": "string" },
      "rules": {
        "type": "object",
        "properties": {
          "distance_km": { "type": "number", "minimum": 0 },
          "time_window_sec": { "type": "integer", "minimum": 0 },
          "apps": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["time_window_sec"]
      },
      "payout": {
        "type": "object",
        "properties": {
          "success_split": { "type": "string" },
          "fees_bps": {
            "type": "object",
            "properties": {
              "dao": { "type": "integer" },
              "creator": { "type": "integer" },
              "validators": { "type": "integer" },
              "loser_cashback": { "type": "integer" }
            }
          }
        }
      },
      "links": { "type": "object" },
      "version": { "type": "integer" }
    },
    "required": ["kind", "title", "version"]
  }