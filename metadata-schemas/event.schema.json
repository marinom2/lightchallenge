{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "EventMarket",
    "type": "object",
    "properties": {
      "kind": { "const": "Event" },
      "title": { "type": "string" },
      "description": { "type": "string" },
      "image": { "type": "string" },
      "outcomes": {
        "type": "array",
        "minItems": 2,
        "items": { "type": "string" }
      },
      "cutoff_ts": { "type": "integer" },
      "resolve_by": { "type": "string" },
      "payout": {
        "type": "object",
        "properties": {
          "model": { "type": "string" },
          "fees_bps": {
            "type": "object",
            "properties": {
              "dao": { "type": "integer" },
              "creator": { "type": "integer" },
              "validators": { "type": "integer" }
            }
          }
        }
      },
      "jurisdictions_blocked": {
        "type": "array",
        "items": { "type": "string" }
      },
      "age_restriction": { "type": "integer" },
      "version": { "type": "integer" }
    },
    "required": ["kind", "title", "outcomes", "version"]
  }