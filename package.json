{
  "name": "lightchallenge",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "//": "── Build / Clean ─────────────────────────────────────────────",
    "build": "hardhat compile",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf artifacts cache typechain-types || true",
    "clean:all": "rimraf artifacts cache typechain-types coverage || true",
    "//2": "── Format / Lint ──────────────────────────────────────────────",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "//3": "── Deploy / Admin ────────────────────────────────────────────",
    "deploy": "hardhat run scripts/ops/deploy.ts --network lightchain",
    "deploy:lightchain": "hardhat run scripts/deploy/01_deploy_challengepay.ts --network lightchain",
    "deploy:registry": "hardhat run scripts/admin/deployRegistry.ts --network lightchain",
    "registry:set": "hardhat run scripts/admin/registrySet.ts --network lightchain",
    "registry:get": "hardhat run scripts/ops/registryGet.ts --network lightchain",
    "deploy:verifier": "hardhat run scripts/admin/deployMockVerifier.ts --network lightchain",
    "deploy:aivm:auto": "bash -c 'AIVM_VERIFIER=$(npm run --silent deploy:aivm | tee /dev/stderr | sed -n \"s/^AivmProofVerifier deployed at: //p\") && export AIVM_VERIFIER && echo AIVM_VERIFIER=$AIVM_VERIFIER'",
    "deploy:treasury": "hardhat run scripts/admin/deployTreasury.ts --network lightchain",
    "set:treasury": "hardhat run scripts/admin/setTreasury.ts --network lightchain",
    "deployments:normalize": "ts-node scripts/ops/normalizeDeployments.ts",
    "deploy:idempotent": "hardhat run scripts/deploy/idempotent.ts --network lightchain",
    "verify:all": "hardhat verify:all --network lightchain",
    "events:backfill": "ts-node scripts/events/backfill.ts",
    "//3.1": "── Access Control (Treasury) ─────────────────────────────────",
    "roles": "hardhat run --network lightchain scripts/admin/roles.ts",
    "set:fees": "hardhat run scripts/admin/setFeeConfig.ts --network lightchain",
    "meta:set": "hardhat run scripts/admin/setChallengeMeta.ts --network lightchain",
    "meta:get": "hardhat run scripts/ops/getChallengeMeta.ts --network lightchain",
    "set:lead": "hardhat run scripts/ops/setLead.ts --network lightchain",
    "set:validatorParams": "hardhat run scripts/ops/setValidatorParams.ts --network lightchain",
    "//4": "── Challenge lifecycle ───────────────────────────────────────",
    "create": "hardhat run scripts/ops/createChallenge.ts --network lightchain",
    "approve": "hardhat run scripts/ops/approve.ts --network lightchain",
    "submitProof": "hardhat run scripts/ops/submitProof.ts --network lightchain",
    "proof:compose": "hardhat run scripts/ops/composeAndSubmitProof.ts --network lightchain",
    "deploy:msigverifier": "hardhat run scripts/admin/deployMultiSigVerifier.ts --network lightchain",
    "msig:set": "hardhat run scripts/admin/setAttesters.ts --network lightchain",
    "msig:add": "SET=$ADDR hardhat run scripts/admin/setAttesters.ts --network lightchain",
    "msig:remove": "UNSET=$ADDR hardhat run scripts/admin/setAttesters.ts --network lightchain",
    "msig:threshold": "THRESH=$M hardhat run scripts/admin/setAttesters.ts --network lightchain",
    "msig:bootstrap": "hardhat run scripts/admin/bootstrapAttesters.ts --network lightchain",
    "peer:vote": "hardhat run scripts/ops/peerVote.ts --network lightchain",
    "finalize": "hardhat run scripts/ops/finalize.ts --network lightchain",
    "cancel": "hardhat run scripts/admin/cancelChallenge.ts --network lightchain",
    "//5": "── Participation / Bets ─────────────────────────────────────",
    "join": "hardhat run scripts/ops/join.ts --network lightchain",
    "bet": "hardhat run scripts/ops/bet.ts --network lightchain",
    "//6": "── Claims ───────────────────────────────────────────────────",
    "claim:winner": "hardhat run scripts/ops/claimWinner.ts --network lightchain",
    "claim:loser": "hardhat run scripts/ops/claimLoserCashback.ts --network lightchain",
    "claim:validator": "hardhat run scripts/ops/claimValidator.ts --network lightchain",
    "claim:auto": "hardhat run scripts/ops/claimAuto.ts --network lightchain",
    "//7": "── Validators lifecycle ─────────────────────────────────────",
    "ops:stake": "hardhat run scripts/ops/stakeValidator.ts --network lightchain",
    "ops:unstake:req": "hardhat run scripts/ops/requestUnstake.ts --network lightchain",
    "ops:unstake:wd": "hardhat run scripts/ops/withdrawUnstaked.ts --network lightchain",
    "ops:listValidators": "hardhat run scripts/ops/listValidators.ts --network lightchain",
    "//8": "── Inspect / Status ─────────────────────────────────────────",
    "status": "hardhat run scripts/inspect/status.ts --network lightchain",
    "status:json": "MODE=json hardhat run scripts/inspect/status.ts --network lightchain",
    "list": "hardhat run scripts/inspect/listChallenges.ts --network lightchain",
    "list:json": "MODE=json hardhat run scripts/inspect/listChallenges.ts --network lightchain",
    "export": "hardhat run scripts/exportChallenge.ts --network lightchain",
    "snapshot": "hardhat run scripts/inspect/getSnapshot.ts --network lightchain",
    "inspect:pools": "hardhat run scripts/inspect/pools.ts --network lightchain",
    "inspect:creator": "hardhat run scripts/inspect/creatorView.ts --network lightchain",
    "inspect:myPayout": "hardhat run scripts/inspect/myPayout.ts --network lightchain",
    "//8.1": "── Snapshot helper (timestamped file to snapshots/) ─────────",
    "snapshot:challenge": "node -e \"console.log('Set CH_ID and run: npm run snapshot:challenge:run')\"",
    "snapshot:challenge:run": "CH_ID=$CH_ID node scripts/inspect/export-and-save.mjs",
    "//9": "── Health / Gas / Tests ─────────────────────────────────────",
    "ping": "hardhat run scripts/ops/rpcHealth.ts --network lightchain",
    "gas": "GAS_REPORT=1 hardhat test",
    "test": "hardhat test",
    "test:watch": "nodemon --watch contracts --watch test --ext sol,ts --ignore typechain-types --exec \"npm test\"",
    "test:watch:grep": "nodemon --watch contracts --watch test --ext sol,ts --ignore typechain-types --exec",
    "test:file": "hardhat test --grep \"$TEST\"",
    "coverage": "hardhat coverage --testfiles 'test/**/*.spec.ts'",
    "coverage:check": "node scripts/ci/check-coverage.mjs",
    "coverage:ci": "npm run coverage && npm run coverage:check",
    "//10": "── CI bundles / convenience ─────────────────────────────────",
    "check": "npm run build && npm run typecheck && npm run lint && npm run format:check",
    "ci": "npm run check && npm run test",
    "ci:full": "npm run check && npm run coverage:ci",
    "//11": "── Utilities ────────────────────────────────────────────────",
    "export:abis": "hardhat run scripts/deploy/01_deploy_challengepay.ts --network lightchain",
    "check:deploy": "hardhat run scripts/inspect/checkDeployments.ts --network lightchain",
    "inference:sign": "hardhat run scripts/ops/signAivmProof.ts --network lightchain",
    "ocr:steps": "hardhat run scripts/ingest/ocr_screenshot.ts",
    "deploy:router": "hardhat run scripts/admin/deployEventRouter.ts --network lightchain",
    "router:event": "hardhat run scripts/admin/registerEvent.ts --network lightchain",
    "router:outcome": "hardhat run scripts/admin/addOutcome.ts --network lightchain",
    "router:uri": "hardhat run scripts/admin/setEventURI.ts --network lightchain",
    "router:finalize": "hardhat run scripts/ops/finalizeEvent.ts --network lightchain",
    "deploy:aivm": "hardhat run scripts/admin/deployAivmVerifier.ts --network lightchain",
    "aivm:signers": "hardhat run scripts/admin/setAivmSigners.ts --network lightchain",
    "set:proof": "hardhat run scripts/ops/setProofConfig.ts --network lightchain",
    "submit:zk": "hardhat run scripts/ops/submitResultZK.ts --network $HARDHAT_NETWORK",
    "deploy:all": "hardhat run scripts/deploy/all.ts --network $HARDHAT_NETWORK"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.14",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.1",
    "@openzeppelin/contracts": "^5.0.2",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.17",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "chai": "^4.4.1",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "hardhat": "^2.26.3",
    "hardhat-deploy": "^0.12.4",
    "hardhat-gas-reporter": "^1.0.10",
    "mocha": "^10.2.0",
    "nodemon": "^3.1.10",
    "p-limit": "^7.1.1",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "solidity-coverage": "^0.8.16",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.2",
    "viem": "^2.37.8"
  },
  "dependencies": {
    "@web3modal/wagmi": "^5.1.11",
    "csv-parse": "^6.1.0",
    "date-fns": "^4.1.0",
    "ethers": "^6.13.2",
    "fast-xml-parser": "^5.2.5",
    "tesseract.js": "^6.0.1",
    "wagmi": "^2.17.5"
  },
  "solidity-coverage": {
    "check": true,
    "branches": 50,
    "functions": 60,
    "lines": 75,
    "statements": 70
  }
}
