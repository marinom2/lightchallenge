import fs from "node:fs";
import { XMLParser } from "fast-xml-parser";
import { Activity } from "../inference/metrics";

/**
 * Apple Health export: export.xml -> sum HKQuantityTypeIdentifierStepCount by day
 */
export function normalizeAppleHealthSteps(xmlPath: string, athleteAddress: string, fromISO?: string, toISO?: string) {
  const xml = fs.readFileSync(xmlPath, "utf8");
  const parser = new XMLParser({ ignoreAttributes: false, attributeNamePrefix: "" });
  const j = parser.parse(xml);
  const recs = j.HealthData?.Record || [];
  const steps: Record<string, number> = {};
  for (const r of recs) {
    if (r.type !== "HKQuantityTypeIdentifierStepCount") continue;
    const sDate = new Date(r.startDate);
    const d = sDate.toISOString().slice(0,10);
    const val = Number(r.value || 0);
    steps[d] = (steps[d] || 0) + val;
  }
  const activities: Activity[] = Object.keys(steps).map((d): Activity => {
    const start = new Date(d + "T00:00:00Z").toISOString();
    const end   = new Date(d + "T23:59:59Z").toISOString();
    return { type: "steps", start, end, steps_count: steps[d] };
  }).filter(a => {
    if (fromISO && a.start < fromISO) return false;
    if (toISO && a.end > toISO) return false;
    return true;
  });

  return { athlete: { address: athleteAddress, source: "apple_health" }, activities };
}
