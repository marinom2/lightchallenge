import fs from "node:fs";
import { XMLParser } from "fast-xml-parser";
import { parse as parseCsv } from "csv-parse/sync";
import { Activity } from "../inference/metrics";

/** Normalize Garmin GPX run/cycle file */
export function normalizeGarminGpx(gpxPath: string, type: Activity["type"], athleteAddress: string) {
  const xml = fs.readFileSync(gpxPath, "utf8");
  const parser = new XMLParser({ ignoreAttributes: false });
  const g = parser.parse(xml);
  const trk = g.gpx?.trk;
  const seg = (trk?.trkseg?.trkpt) || [];
  const gps_path: [number, number][] = seg.map((p: any) => [Number(p['@_lat']), Number(p['@_lon'])]);
  const start = seg[0]?.time || new Date().toISOString();
  const end   = seg[seg.length-1]?.time || start;

  // crude totals
  let distance_km = 0;
  for (let i=1;i<gps_path.length;i++) {
    distance_km += haversine(gps_path[i-1], gps_path[i]);
  }
  const activities: Activity[] = [{
    type, start, end, distance_km, duration_min: undefined, elev_gain_m: undefined, gps_path
  }];

  return { athlete: { address: athleteAddress, source: "garmin" }, activities };
}

/** Normalize Garmin daily steps CSV export: date, steps */
export function normalizeGarminStepsCsv(csvPath: string, athleteAddress: string, fromISO?: string, toISO?: string) {
  const csv = fs.readFileSync(csvPath, "utf8");
  const rows = parseCsv(csv, { columns: true, skip_empty_lines: true });
  const activities: Activity[] = rows.map((r: any): Activity => {
    const date = r.date || r.Date || r.DAY || r.day;
    const steps = Number(r.steps || r.Steps || r.STEPS || r.step_count || 0);
    const start = new Date(date + "T00:00:00Z").toISOString();
    const end   = new Date(date + "T23:59:59Z").toISOString();
    return { type: "steps", start, end, steps_count: steps };
  }).filter((a: Activity) => {
    if (fromISO && a.start < fromISO) return false;
    if (toISO && a.end   > toISO) return false;
    return true;
  });

  return { athlete: { address: athleteAddress, source: "garmin" }, activities };
}

// Haversine in km
function haversine(a: [number, number], b: [number, number]): number {
  const toRad = (x: number) => x * Math.PI / 180;
  const R = 6371;
  const dLat = toRad(b[0]-a[0]); const dLon = toRad(b[1]-a[1]);
  const lat1 = toRad(a[0]); const lat2 = toRad(b[0]);
  const s = Math.sin(dLat/2)**2 + Math.cos(lat1)*Math.cos(lat2)*Math.sin(dLon/2)**2;
  return 2*R*Math.asin(Math.sqrt(s));
}
