# =============================================================================
# LightChallenge — Environment Variables Reference
# =============================================================================
# Copy this file to webapp/.env.local and fill in your values.
# All off-chain workers and scripts also read from webapp/.env.local via dotenv.
#
# Legend:  [REQUIRED] must be set  |  [RECOMMENDED] degrades without  |  (optional)
#
# Sections:
#   1. Chain / RPC
#   2. Contract Addresses
#   3. Private Keys & Signers
#   4. AIVM / Inference
#   5. Database
#   6. Off-chain Workers
#   7. External APIs
#   8. Webapp (public / client-side)
#   9. Security
#  10. Hardhat / Deploy (only needed for contract deployment)
# =============================================================================


# ── 1. Chain / RPC ────────────────────────────────────────────────────────────

NEXT_PUBLIC_CHAIN_ID=504
NEXT_PUBLIC_RPC_URL=https://light-testnet-rpc.lightchain.ai

# Off-chain worker RPC (preferred over NEXT_PUBLIC_RPC_URL for backend services)
LCAI_RPC=https://light-testnet-rpc.lightchain.ai
LCAI_CHAIN_ID=504

# Explorer
NEXT_PUBLIC_EXPLORER_URL=https://testnet.lightscan.app

# Native token symbol shown in the UI
NEXT_PUBLIC_NATIVE_SYMBOL=LCAI


# ── 2. Contract Addresses ─────────────────────────────────────────────────────
# These are auto-read from public/deployments/lightchain.json.
# Set overrides only if you need to point at a different deployment.

# NEXT_PUBLIC_CHALLENGEPAY_ADDR=0x...
# NEXT_PUBLIC_TREASURY_ADDR=0x...

# [REQUIRED] Lightchain-deployed AIVM contract (do not change unless testnet resets)
AIVM_INFERENCE_V2_ADDRESS=0x2d499C52312ca8F0AD3B7A53248113941650bA7E

# [REQUIRED] Our deployed ChallengeTaskRegistry
CHALLENGE_TASK_REGISTRY_ADDRESS=0x...


# ── 3. Private Keys & Signers ─────────────────────────────────────────────────

# [REQUIRED] Worker wallet: submits AIVM inference requests on-chain.
# Must be funded with LCAI for gas + request fees.
LCAI_WORKER_PK=0x<64-hex>

# [REQUIRED] Finalization wallet: submits proofs and finalizes challenges.
# Used by the AIVM indexer bridge. Can be the same as LCAI_WORKER_PK.
LCAI_FINALIZE_PK=0x<64-hex>

# [RECOMMENDED] Admin secret for admin API endpoints (models, templates).
# Webapp API routes compare this against the x-admin-key header.
ADMIN_KEY=<secret-string>

# MetadataRegistry signer: writes metadata URIs on-chain via ownerSet().
# Must be the MetadataRegistry owner wallet. Falls back to ADMIN_KEY if not set.
# METADATA_REGISTRY_KEY=0x<64-hex>

# AIVM operator key (used by deploy scripts to configure verifier ownership)
# AIVM_OPERATOR_PRIVKEY=0x<64-hex>


# ── 4. AIVM / Inference ───────────────────────────────────────────────────────

# Fee sent with each requestInferenceV2 call (wei). Default: 0.001 LCAI
AIVM_REQUEST_FEE_WEI=1000000000000000


# ── 5. Database ───────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string (Neon or self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require


# ── 6. Off-chain Workers ──────────────────────────────────────────────────────
# All workers have sensible defaults — override only if needed.

# Evidence collector (polls provider APIs for activity data)
# EVIDENCE_COLLECTOR_POLL_MS=300000       # 5 minutes
# EVIDENCE_COLLECTOR_LOOKBACK_DAYS=90

# Evidence evaluator (converts evidence → verdicts)
# EVIDENCE_EVALUATOR_POLL_MS=15000
# EVIDENCE_EVALUATOR_BATCH=50

# Challenge dispatcher (queues approved challenges with verdicts into aivm_jobs)
# CHALLENGE_DISPATCHER_POLL_MS=10000
# CHALLENGE_DISPATCHER_SCAN_LIMIT=200

# Challenge worker (submits AIVM requests for queued jobs)
# CHALLENGE_WORKER_POLL_MS=5000
# CHALLENGE_WORKER_CONCURRENCY=2
# CHALLENGE_WORKER_MAX_ATTEMPTS=10

# AIVM indexer (indexes Lightchain AIVM events; bridges finalization)
# AIVM_INDEXER_POLL_MS=4000

# Status indexer (syncs ChallengePay status events → public.challenges.status)
# STATUS_INDEXER_POLL_MS=6000

# Claims indexer (indexes ChallengePay claim events → public.claims)
# CLAIMS_INDEXER_POLL_MS=6000

# Reorg protection: number of confirmation blocks before processing events.
# Higher = safer but slower finality. Default: 12
# CONFIRMATION_BLOCKS=12


# ── 7. External APIs ──────────────────────────────────────────────────────────

# Steam Web API (gaming evidence + linked accounts)
# STEAM_WEBAPI_KEY=

# OpenDota API (Dota 2 evidence)
# OPENDOTA_BASE=https://api.opendota.com
# OPENDOTA_KEY=

# Riot Games API (League of Legends evidence / PUUID resolution)
# RIOT_API_KEY=
# RIOT_REGION=europe
# RIOT_PLATFORM=euw1

# Strava OAuth (fitness evidence — auto-collection)
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=

# Fitbit OAuth (fitness evidence — auto-collection)
# FITBIT_CLIENT_ID=
# FITBIT_CLIENT_SECRET=

# FACEIT Data API (CS2 evidence — auto-collection via FACEIT)
# Get a free key at https://developers.faceit.com
# FACEIT_API_KEY=


# ── 8. Webapp (public / client-side) ─────────────────────────────────────────

# [RECOMMENDED] WalletConnect project ID (required for wallet connect modal)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Base URL for server-side absolute URLs (metadata URIs, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Max budget shown in create challenge UI (LCAI)
# NEXT_PUBLIC_MAX_BUDGET_LCAI=0.02


# ── 9. Security ──────────────────────────────────────────────────────────────

# [REQUIRED for production] 32-byte hex key for encrypting OAuth tokens at rest.
# Generate with: openssl rand -hex 32
# If unset, tokens are stored in plaintext (acceptable for local dev only).
OAUTH_ENCRYPTION_KEY=<64-hex>

# Signer key for AIVM proof bindings + Steam identity verification (EIP-712).
# Falls back to AIVM_OPERATOR_PRIVKEY if not set.
# AIVM_SIGNER_KEY=0x<64-hex>

# IPFS gateway for resolving challenge metadata URIs (default: ipfs.io)
# IPFS_GATEWAY=https://ipfs.io/ipfs/


# ── 9b. Gasless Relay (optional) ────────────────────────────────────────────
# Enable EIP-2771 meta-transaction relay (TrustedForwarder).
# All three must be set to activate the relay endpoint.

# RELAY_ENABLED=false
# RELAYER_PRIVATE_KEY=0x<64-hex>
# NEXT_PUBLIC_TRUSTED_FORWARDER=0x<address>


# ── 10. Hardhat / Deploy ──────────────────────────────────────────────────────
# Only needed when running deploy scripts (npx hardhat deploy ...)

# [REQUIRED for deploy] Deployer wallet (must be funded with LCAI for gas)
# PRIVATE_KEY=0x<64-hex>

# [REQUIRED for deploy] Admin wallet
# ADMIN_PRIVATE_KEY=0x<64-hex>
# ADMIN_ADDRESS=0x<40-hex>

# Use admin key for admin transactions (0 = deployer, 1 = admin key)
# USE_ADMIN_KEY=0

# Treasury initial operator address
# TREASURY_INITIAL_OPERATOR=0x<address>

# Force re-deploy (1 = re-deploy; destructive, all on-chain state lost)
# REDEPLOY_CHALLENGEPAY=0
# REDEPLOY_ACHIEVEMENT=0

# Auto-run post-deploy config (fee setup, dispatcher registration, etc.)
# RUN_POST_DEPLOY_CONFIG=true

# Gas reporting for tests
# GAS_REPORT=true
# CMC_API_KEY=
